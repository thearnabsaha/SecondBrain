# --- LLM ---
# Groq API key for note extraction, summaries, and Q&A.
# Get one free at https://console.groq.com
GROQ_API_KEY=

# Optional. By default the app tries this fallback chain in order, retrying
# each model up to 2x with backoff before falling through:
#   1. openai/gpt-oss-120b
#   2. openai/gpt-oss-20b
#   3. openai/gpt-oss-safeguard-20b
#   4. llama-3.3-70b-versatile
#
# Set GROQ_MODEL to a single model to disable fallback (useful for debugging).
# Set GROQ_MODELS to a comma-separated list to override the chain.
# GROQ_MODEL=
# GROQ_MODELS=openai/gpt-oss-120b,llama-3.3-70b-versatile

# --- LLM networking (optional) ---
# If your network blocks api.groq.com (corporate proxy / VPN URL filter),
# either route through an HTTP forward proxy or point at a reachable mirror.
# Run `npm run llm:doctor` to detect blocking and get tailored advice.
# HTTPS_PROXY=http://your.proxy.host:port
# GROQ_BASE_URL=https://api.groq.com

# --- Web enrichment (optional but recommended) ---
# Tavily API key for the "Enrich" feature on profiles. Free tier: 1000 req/mo.
# https://app.tavily.com
TAVILY_API_KEY=

# --- Database ---
# Postgres connection string. Easiest path: free Neon project at https://neon.tech
# (copy the pooled connection string and paste here). On Vercel, connecting a
# Neon store from the project dashboard sets this automatically.
POSTGRES_URL=

# --- Auth ---
# Secret used to sign session JWTs. Generate one with:
#   openssl rand -base64 48
# Or in PowerShell:
#   [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 } | ForEach-Object { [byte]$_ }))
AUTH_SECRET=
