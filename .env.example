# --- LLM ---
# Groq API key for note extraction, summaries, and Q&A.
# Get one free at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Web enrichment (optional but recommended) ---
# Tavily API key for the "Enrich" feature on profiles. Free tier: 1000 req/mo.
# https://app.tavily.com
TAVILY_API_KEY=

# --- Database ---
# Postgres connection string. Easiest path: free Neon project at https://neon.tech
# (copy the pooled connection string and paste here). On Vercel, connecting a
# Neon store from the project dashboard sets this automatically.
POSTGRES_URL=

# --- Auth ---
# Secret used to sign session JWTs. Generate one with:
#   openssl rand -base64 48
# Or in PowerShell:
#   [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 } | ForEach-Object { [byte]$_ }))
AUTH_SECRET=
